
// Extracts the shadow index from the packed light type.
// If the index is >= 0, the light has shadows associated with it.
int extractShadowIndex(int packedLightType) {
    return (packedLightType >> 2) - 1;
}

// Extracts the light type from the packed light type.
int normalizeLightType(int packedLightType) {
    return packedLightType & 3;
}

float linearizeDepth(float depth, vec2 lightRangeInverse) {
    // lightRangeInverse.y = 1 / (rangeMaxInverse - rangeMinInverse)
    // = 1 / (1/rangeMax - 1/rangeMin)
    // = 1 / ((rangeMin - rangeMax) / rangeMax*rangeMin)
    // = rangeMax*rangeMin / (rangeMin-rangeMax)
    return (1.0/depth - lightRangeInverse.x) * lightRangeInverse.y;
}

// Checks if the screenspace pixel is exposed to the current light
// by looking up the light's screenspace contribution in the contribution map.
bool isExposedToLight(int shadowIndex, sampler2D contributionMap, vec2 uv) {
    if (shadowIndex >= 0) {
        uint table = floatBitsToUint(texture(contributionMap, uv).r);
        return ((table >> shadowIndex) & 1u) == 1;
    }
    return true;
}

bool isExposedToLight(int shadowIndex, sampler3D contributionMap, vec3 texCoord) {
    if (shadowIndex >= 0) {
        int table = int(textureLod(contributionMap, texCoord, 0.0).r);
        return ((table >> shadowIndex) & 1) == 1;
    }
    return true;
}

// Checks if the world position is exposed to the current light
// by comparing the position's lightspace depth against the shadow map.
bool isExposedToLight(vec3 worldPos, sampler2D shadowMap, mat4 lightViewProjectionMatrix, vec2 lightRangeInverse, bool outOfBoundsExposed) {
    vec4 lightViewPos = lightViewProjectionMatrix * vec4(worldPos, 1.0);
    vec3 lightUv = ((lightViewPos.xyz / lightViewPos.w) + 1.0) * 0.5;
    float depth = lightUv.z;
    if (depth >= 0.0 && lightUv.x >= 0.0 && lightUv.x <= 1.0 && lightUv.y >= 0.0 && lightUv.y <= 1.0) {
        float shadow = textureLod(shadowMap, lightUv.xy, 0.0).r;
        return depth - 0.001 <= shadow;
    }
    return outOfBoundsExposed;
}

float depthDebug(vec3 worldPos, sampler2D shadowMap, mat4 lightViewProjectionMatrix, vec2 lightRangeInverse) {
    vec4 lightViewPos = lightViewProjectionMatrix * vec4(worldPos, 1.0);
    //vec2 lightUv = (lightViewPos.xy / lightViewPos.w + 1.0) * 0.5;
    return lightViewPos.z;
}

