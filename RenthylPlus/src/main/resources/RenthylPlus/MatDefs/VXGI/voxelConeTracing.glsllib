
const vec3 voxelSize = (GRID_MAX - GRID_MIN) / GRID_SIZE;
const vec3 gridSizeInverse = 1.0 / (GRID_MAX - GRID_MIN);
const mat3 seedScalars = mat3(1.0, 1.56, 0.68, 0.91, 0.33, 1.87, 1.34, 1.79, 0.48);

#ifndef TRACE_DISPLACEMENT
    #define TRACE_DISPLACEMENT 0.0
#endif

vec3 worldToVoxelSpace(vec3 worldPos) {
    return (worldPos - GRID_MIN) * gridSizeInverse;
}

bool withinVoxelGridBounds(vec3 worldPos) {
    return worldPos.x >= GRID_MIN.x && worldPos.x <= GRID_MAX.x
        && worldPos.y >= GRID_MIN.y && worldPos.y <= GRID_MAX.y
        && worldPos.z >= GRID_MIN.z && worldPos.z <= GRID_MAX.z;
}

vec3 orthogonal(vec3 vec, vec3 w) {
    if (dot(vec, w) > 0.9) {
        w = -w.yzx;
    }
    return normalize(cross(vec, w));
}

float maxVoxelSize() {
    return max(max(voxelSize.x, voxelSize.y), voxelSize.z);
}

float interpolateLinear(float a, float b, float f) {
    return (b - a) * f + a;
}

float random(float s) {
    return abs(fract(sin(s) * 19342.234));
}

vec3 random3(vec3 v){
    v = fract(v * vec3(443.897, 441.423, 437.195));
    v += dot(v, v.zxy + vec3(31.31));
    return normalize(fract((v.xyz + v.yzx) * v.zyx) * 2.0 - 1.0);
}

vec3 randomHemisphere(mat3 space, float seed) {
    vec3 v = fract(vec3(443.897, 441.423, 437.195) * seed);
    v += dot(v, v.zxy + vec3(31.31));
    v = normalize(fract((v.xyz + v.yzx) * v.zyx));
    v.z = abs(v.z);
    return space * v;
}

float mapRange(float v, float inMin, float inMax, float outMin, float outMax) {
    return (outMax - outMin) * ((v - inMin) / (inMax - inMin)) + outMin;
}

float mapRangeClamp(float v, float inMin, float inMax, float outMin, float outMax) {
    return (outMax - outMin) * clamp((v - inMin) / (inMax - inMin), 0.0, 1.0) + outMin;
}

vec4 traceVoxelCone(vec3 origin, vec3 direction, float apertureTan2, float quality) {
    float voxSize = maxVoxelSize(); // maximum voxel size demension
    float voxSizeInverse = 1.0 / voxSize; // inverse of the max voxel size
    direction = normalize(direction); // ensure the direction is normalized
    quality = max(0.1, quality); // add a quality threshold so I don't snipe myself
    float dist = voxSize * 2.2; // distance away from the origin we are sampling
    float occlusion = 0.0; // the cone's ability to receive color (0=full, 1=none)
    vec3 color = vec3(0.0); // accumulated color
    origin += direction * voxSize * 1.25; // ensure we start by sampling a neighboring voxel
    while (occlusion < 1.0) { // trace until the cone cannot receive more color
        vec3 pos = origin + direction * dist;
        if (!withinVoxelGridBounds(pos)) {
            // the cone has effectively left the voxel grid
            break;
        }
        float diameter = dist * apertureTan2;
        float lod = log2(diameter * voxSizeInverse); // find mipmap that fits the sample diameter
        vec4 s = textureLod(TRACING_VOXEL_MAP, worldToVoxelSpace(pos), lod);
        color += s.rgb * max(1.0 - occlusion, 0.0); // accumulate color
        occlusion += s.a * 1.2; // add occlusion to the cone
        dist += diameter * quality; // move to next sample
    }
    // the occlusion now represents how exposed to the sky the cone's origin is (0=full, 1=none)
    occlusion = 1.0 - clamp(occlusion, 0.0, 1.0); // clamp and flip so the occlusion is usable
    //occlusion = mapRange(occlusion, 0.0, 1.0, 0.2, 1.0); // remap range so that it isn't as intense
    //occlusion *= mapRangeClamp(dist, 1.0, 10.0, 0.2, 1.0); // factor in the distance the cone travelled
    return vec4(color * occlusion, occlusion);
}

vec4 traceVoxelConeAngle(vec3 origin, vec3 direction, float angle, float quality) {
    return traceVoxelCone(origin, direction, 2.0 * tan(angle), quality);
}

vec4 approximateSurfaceIndirectVXGI(vec3 worldPos, mat3 tanSpace, vec3 worldNormal, vec3 viewDir, float metallic, float roughness, vec3 specular, float quality) {
    float angle = radians(30.0);
    float apertureTan2 = 2.0 * tan(angle);
    worldPos += worldNormal * maxVoxelSize() * 1.0;
    // diffuse
    vec4 color = traceVoxelCone(worldPos, tanSpace * vec3(0.0, 0.0, 1.0), apertureTan2, quality) * roughness;
    color += traceVoxelCone(worldPos, tanSpace * vec3(1.0, 0.0, 1.0), apertureTan2, quality) * roughness;
    color += traceVoxelCone(worldPos, tanSpace * vec3(-1.0, 0.0, 1.0), apertureTan2, quality) * roughness;
    color += traceVoxelCone(worldPos, tanSpace * vec3(0.0, 1.0, 1.0), apertureTan2, quality) * roughness;
    color += traceVoxelCone(worldPos, tanSpace * vec3(0.0, -1.0, 1.0), apertureTan2, quality) * roughness;
    // specular
    color += traceVoxelConeAngle(worldPos, reflect(viewDir, worldNormal), interpolateLinear(0.01, angle, roughness), quality) * vec4(specular, 1.0);
    return color;
}

vec4 approximateSurfaceIndirectVXGI(vec3 worldPos, vec3 worldNormal, vec3 viewDir, float metallic, float roughness, vec3 specular, float quality) {
    // build tangent space matrix
    vec3 xtan = orthogonal(worldNormal, vec3(0.0, 1.0, 0.0));
    vec3 ytan = cross(worldNormal, xtan);
    mat3 tanSpace = mat3(xtan, ytan, worldNormal);
    return approximateSurfaceIndirectVXGI(worldPos, tanSpace, worldNormal, viewDir, metallic, roughness, specular, quality);
}

vec4 approximatePositionIndirectVXGI(vec3 worldPos, vec3 bias, float quality, float seed) {
    float angle = radians(30.0);
    float apertureTan2 = 2.0 * tan(angle);
    vec3 xtan = orthogonal(bias, vec3(0.0, 1.0, 0.0));
    vec3 ytan = cross(bias, xtan);
    mat3 tanSpace = mat3(xtan, ytan, bias);
    vec4 color = traceVoxelCone(worldPos, randomHemisphere(tanSpace, seed), apertureTan2, quality);
    color += traceVoxelCone(worldPos, randomHemisphere(tanSpace, seed * 1.353), apertureTan2, quality);
    color += traceVoxelCone(worldPos, randomHemisphere(tanSpace, seed * 1.831), apertureTan2, quality);
    return color;
}


